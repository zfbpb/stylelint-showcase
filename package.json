{
  "name": "stylelint-showcase",
  "version": "1.0.0",
  "description": "Default Stylelint configuration and usage example.",
  "scripts": {
    "dev": "concurrently \"sass --watch scss/main.scss:css/main.css\" \"live-server --open=/ --watch=.\" \"pnpm lint:styles:watch\"",
    "build": "sass scss/main.scss css/main.css",
    "lint:styles": "stylelint \"scss/**/*.scss\"",
    "lint:styles:verbose": "stylelint \"scss/**/*.scss\" --formatter verbose",
    "lint:styles:watch": "chokidar \"scss/**/*.scss\" -c \"pnpm lint:styles:verbose\""
  },
  "packageManager": "pnpm@10.15.1",
  "devDependencies": {
    "@stylistic/stylelint-plugin": "^5.0.1",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.0.1",
    "live-server": "^1.2.2",
    "sass": "^1.93.2",
    "stylelint": "^17.6.0",
    "stylelint-config-standard-scss": "^17.0.0"
  },
  "dependencies": {
    "normalize.css": "^8.0.1"
  }
}
